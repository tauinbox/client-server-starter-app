APPLICATION_PORT=3000
ENVIRONMENT=local

# Set to true to enable Swagger UI in staging/production (disabled by default outside local/development)
# SWAGGER_ENABLED=true

# Request logging level: all (default) | warn (4xx+5xx only) | error (5xx only)
REQUEST_LOG_LEVEL=all

EXTERNAL_API=http://third-part-api.url
EXTERNAL_API_TOKEN=api-token

DB_HOST=localhost
DB_PORT=5432
DB_NAME=my-db
DB_USER=postgres
DB_PASSWORD=password
DB_SCHEMA=
# Logging: "warn" and "error" always recommended; "slow" logs queries exceeding DB_SLOW_QUERY_THRESHOLD.
# For verbose query debugging add "query" to the array.
DB_LOGGING=["warn","error","slow"]
DB_SLOW_QUERY_THRESHOLD=200
DB_LOGGER=
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Comma-separated list of allowed origins for CORS (e.g. https://app.example.com,https://admin.example.com)
# Set to * only in non-production environments (wildcard is rejected when ENVIRONMENT=production)
# Leave unset when a reverse proxy (Caddy, nginx) serves client and API from the same origin
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Reverse-proxy trust setting — forwarded to Express `app.set('trust proxy', ...)`.
# Required when running behind nginx / Caddy / K8s ingress / Cloudflare so that
# `req.ip` resolves to the real client IP (from `X-Forwarded-For`) instead of
# the proxy's IP. Affects rate-limiting (@nestjs/throttler), account-lockout
# throttler, and audit-log IP recording.
# Accepted values:
#   loopback              - trust 127.0.0.1 / ::1 (local dev proxy)
#   linklocal             - trust 169.254.0.0/16, fe80::/10
#   uniquelocal           - trust private ranges 10/8, 172.16/12, 192.168/16, fc00::/7
#   10.0.0.0/8            - a single CIDR block
#   10.0.0.1,10.0.0.2     - comma-separated IP list
#   1                     - trust N hops (take the N-th from the right)
#   true                  - trust any proxy (only safe when nothing untrusted can reach the app)
# Leave empty to keep Express defaults (no trust). See server/README.md
# "Deployment behind a reverse proxy" for details.
# TRUSTED_PROXIES=loopback

# Redis (optional for local dev; required for multi-instance deployments)
# When set, used for distributed rate limiting and permission cache sharing
# REDIS_URL=redis://localhost:6379

# JWT Algorithm: HS256 (symmetric) or RS256 (asymmetric, recommended).
# HS256 — single secret for signing and verification; simpler but symmetric.
# RS256 — private key signs, public key verifies; preferred for production.
JWT_ALGORITHM=RS256

# For HS256 only: uncomment and set a secret (min 16 chars).
# Used when JWT_ALGORITHM=HS256; ignored when JWT_ALGORITHM=RS256.
# JWT_SECRET=my_jwt_secret_key_32chars_long!!

# For RS256: base64-encoded PEM keys (required when JWT_ALGORITHM=RS256).
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   JWT_PRIVATE_KEY=$(base64 -w0 private.pem)
#   JWT_PUBLIC_KEY=$(base64 -w0 public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Key rotation: Unix timestamp (seconds) — tokens issued before this value are rejected.
# To rotate keys: generate new key pair, update JWT_PRIVATE_KEY/JWT_PUBLIC_KEY, then set
# JWT_MIN_IAT to the current Unix timestamp (e.g. date +%s) and restart.
# JWT_MIN_IAT=

JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
CLIENT_URL=http://localhost:4200

# Initial admin user (created on first startup if not exists; leave empty to skip)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Audit log retention in days (default: 90); logs older than this are deleted nightly
AUDIT_LOG_RETENTION_DAYS=90

# Cloudflare Turnstile CAPTCHA (optional — leave both empty to disable CAPTCHA).
# Soft-trigger: only required on /register and /forgot-password when the IP is
# near the rate limit (X-RateLimit-Remaining ≤ 1). Both keys must be set for
# CAPTCHA to be enabled.
#
# Local dev / CI test keys (always pass the challenge):
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
#
# WARNING: the test keys above are PUBLIC and provide ZERO abuse protection in
# production. Any bot can mint a passing token from the public test sitekey
# and our test secret will accept it. Real protection requires a Cloudflare
# account:
#   1. Sign in at https://dash.cloudflare.com (free)
#   2. Turnstile → Add site → enter your prod domain → Widget Mode: Managed
#   3. Copy the generated Site Key and Secret Key into the two vars below
#   4. Restart the server container so it re-reads server/.env
# Without prod keys, /register and /forgot-password are protected only by the
# rate-limiter (5/h and 2/5min per IP). See server/README.md
# "Enabling CAPTCHA in production" for the full deploy flow.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# SMTP (leave SMTP_HOST empty to log emails to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
