APPLICATION_PORT=3000
ENVIRONMENT=local

# Request logging level: all (default) | warn (4xx+5xx only) | error (5xx only)
REQUEST_LOG_LEVEL=all

EXTERNAL_API=http://third-part-api.url
EXTERNAL_API_TOKEN=api-token

DB_HOST=localhost
DB_PORT=5432
DB_NAME=my-db
DB_USER=postgres
DB_PASSWORD=password
DB_SCHEMA=
DB_LOGGING=["query","warn","error","log"]
DB_LOGGER=

CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# JWT_SECRET must be at least 16 characters
JWT_SECRET=my_jwt_secret_key_32chars_long!!
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
CLIENT_URL=http://localhost:4200

# Initial admin user (created on first startup if not exists; leave empty to skip)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Audit log retention in days (default: 90); logs older than this are deleted nightly
AUDIT_LOG_RETENTION_DAYS=90

# SMTP (leave SMTP_HOST empty to log emails to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
