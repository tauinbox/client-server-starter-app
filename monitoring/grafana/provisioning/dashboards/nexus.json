      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 15,
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p99_seconds * 1000",
          "legendFormat": "p99 lag",
          "refId": "A"
        }
      ],
      "description": "p99 event loop lag. Values above 10 ms indicate the event loop is blocked — check for synchronous CPU work.",
      "title": "Event Loop Lag (p99)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
