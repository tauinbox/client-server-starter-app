        {
          "expr": "(sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) or vector(0)) / (sum(rate(http_requests_total[5m])) > 0 or vector(1))",
          "legendFormat": "4xx rate",
          "refId": "B"
