# Docker Compose variable substitution (used by db service and image tags)
# Copy this to .env and fill in your values

DB_NAME=mydb
DB_USER=postgres
# On the CI-deployed VPS, DB_PASSWORD is injected from the GitHub secret by
# scripts/sync-prod-env.sh (kept in sync with server/.env). Leave it empty there.
# It must equal the password the postgres data volume was initialized with.
DB_PASSWORD=changeme

# Pre-built image names (for VPS deployment via docker compose pull)
# Format: ghcr.io/<github-username>/nexus-server:latest
SERVER_IMAGE=ghcr.io/your-username/nexus-server:latest
CLIENT_IMAGE=ghcr.io/your-username/nexus-client:latest
